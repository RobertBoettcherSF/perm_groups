------------------------------------------------------------------
--  Permutation Groups in Ada SPARK                              --
--  GNATPROVE Configuration File                                  --
--                                                               --
--  File: gnatprove.config                                        --
--  Description: Configuration for GNATPROVE verification         --
--  Version: 0.01                                               --
--                                                               --
--  Author: Vibe Code Agent                                       --
--  Date: 2024                                                   --
--  Reference: Knuth, D.E. "The Art of Computer Programming"     --
--             Volume 2, Section 4.6.3                            --
------------------------------------------------------------------

-- GNATPROVE configuration for SPARK 2022
-- This file configures the formal verification process

-- General settings
-- Use SPARK 2022 mode
--spark2022

-- Project file to use
--project=perm_groups.gpr

-- Verbosity level (0-5, where 5 is most verbose)
--verbose=3

-- Enable all warnings
--warnings=all

-- Proof settings
-- Enable automatic proof search
--auto

-- Timeout for each proof attempt (in seconds)
--timeout=60

-- Maximum number of proof attempts per goal
--max-attempts=100

-- Enable caching of proof results
--cache=yes

-- Cache directory
--cache-dir=.gnatprove/cache

-- Enable parallel proof checking
--jobs=4

-- Proof level settings
-- Level 0: No proof (just type checking)
-- Level 1: Flow analysis only
-- Level 2: Flow analysis + assertions
-- Level 3: Full proof with pre/post conditions
-- Level 4: Full proof with all contracts

-- For this project, we want full verification
--proof-level=4

-- Enable checking of:
-- - Preconditions
-- - Postconditions
-- - Loop invariants
-- - Loop variants
-- - Assertions
-- - Ghost code

-- Check all contracts
--check=all

-- Enable ghost code (code that doesn't affect execution but helps proofs)
--ghost

-- Enable loop invariant checking
--loop-invariant

-- Enable loop variant checking (for termination)
--loop-variant

-- Enable assertion checking
--assert

-- Enable precondition checking
--pre

-- Enable postcondition checking
--post

-- Enable invariant checking
--invariant

-- Specific settings for permutation group algorithms
-- These algorithms involve complex recursive calls and data structure updates

-- Increase recursion depth for proof search
--recursion-depth=10

-- Enable case analysis for complex conditions
--case-analysis

-- Enable rewriting with equalities
--rewrite

-- Enable arithmetic simplification
--arith

-- Enable boolean simplification
--bool

-- Files to verify
-- Include all source files
--files=src/permutations.ads,src/permutations.adb,\
      src/sims_algorithm.ads,src/sims_algorithm.adb,\
      src/utils.ads,src/utils.adb

-- Exclude test files from verification (they may have non-SPARK code)
--exclude=tests/*,examples/*

-- Enable verification of test files (optional)
-- For development, you might want to verify tests too
--include=tests/*,examples/*

-- Proof strategy for the permutation group algorithms
-- The algorithms A_k(π) and B_k(π) require careful handling of:
-- 1. Recursive calls
-- 2. Data structure invariants (Sigma and T)
-- 3. Permutation properties
-- 4. Group membership conditions

-- Enable induction for recursive algorithms
--induction

-- Enable functional correctness checking
--functional

-- Enable data structure invariant checking
--data-invariant

-- Settings for handling the complex recursive nature of the algorithms
-- These help with the mutual recursion between Algorithm_A and Algorithm_B

-- Enable mutual recursion handling
--mutual-recursion

-- Enable well-founded recursion checking
--well-founded

-- Termination measures for recursive procedures
-- For Algorithm_A and Algorithm_B, the recursion depth decreases with k
--termination-measure=decreasing(k)

-- Enable checking of data structure consistency
-- The Sigma and T data structures must maintain certain invariants
--data-structure-invariant

-- Performance optimization for GNATPROVE
-- These settings can help speed up the verification process

-- Use incremental proof checking
--incremental

-- Enable proof reuse across similar goals
--reuse

-- Enable proof minimization
--minimize

-- Enable parallel processing for large proofs
--parallel

-- Memory settings
-- Increase memory limit for complex proofs
--memory-limit=4096

-- Stack size for deep recursion in proofs
--stack-size=8192
